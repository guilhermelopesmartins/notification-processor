{
    "version": "2.0",
    "logging": {
        "applicationInsights": {
        "samplingSettings": {
            "isEnabled": true,
            "excludedTypes": "Request"
        },
        "enableLiveMetricsFilters": true
        }
    },
    "extensions": {
        "serviceBus": {
            "prefetchCount": 0,
            "maxConcurrentCalls": 1,
            "autoCompleteMessages": false
        }
    },
    "retry": {
        "strategy": "exponentialBackoff",
        "maxRetryCount": 3,
        "minimumInterval": "00:00:02",
        "maximumInterval": "00:00:30"
    }
}